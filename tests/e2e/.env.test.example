# Tekmar E2E Test Configuration
# Copy to .env.test and fill in values.
# If .env.test is absent, values are read from env/.env.development.

# Frontend URL
FRONTEND_URL=http://localhost:4200
API_URL=http://localhost:3000/api/v1

# Test user credentials (created fresh by tests)
TEST_USER_EMAIL_PREFIX=e2e-test
TEST_USER_PASSWORD=E2eTestPass123!
TEST_ORG_NAME=E2E Test Organization

# GitHub integration (required for query execution tests)
GITHUB_TEST_PAT=ghp_your_token
GITHUB_TEST_ORG=your-org-name

# AWS integration (optional — tests skip if not provided)
AWS_TEST_ACCESS_KEY_ID=
AWS_TEST_SECRET_ACCESS_KEY=
AWS_TEST_REGION=
