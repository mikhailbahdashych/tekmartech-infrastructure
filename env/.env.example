# =============================================================================
# Tekmar — Environment Variables Template
# =============================================================================
# Copy this file to .env.development in the same directory:
#   cp .env.example .env.development
#
# The .env.development file is gitignored and contains your local values.
# This .env.example file is committed and serves as documentation.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (tekmar-db Docker service)
# -----------------------------------------------------------------------------
POSTGRES_DB=tekmar_dev
POSTGRES_USER=tekmar
POSTGRES_PASSWORD=tekmar_dev_password

# -----------------------------------------------------------------------------
# tekmar-api (Application API)
# -----------------------------------------------------------------------------
# Connection string for the PostgreSQL database.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# In development, the database runs in Docker on localhost:5432.
DATABASE_URL=postgresql://tekmar:tekmar_dev_password@localhost:5432/tekmar_dev

# HTTP server port for the Application API.
PORT=3000

# Secret key for signing JWT access tokens. Use a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_random_64_byte_hex_string

# Access token lifetime (e.g., 15m, 1h).
JWT_EXPIRATION=15m

# Refresh token lifetime in days.
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Base URL of the Pipeline Service.
PIPELINE_SERVICE_URL=http://localhost:8100

# Encryption key for integration credentials stored in the database.
# Must be exactly 32 bytes (64 hex characters) for AES-256.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_generate_a_random_32_byte_hex_string

# Path for exported files (CSV downloads). Local directory or S3 bucket.
FILE_STORAGE_PATH=./exports

# Allowed CORS origin for the Interface Layer.
CORS_ORIGIN=http://localhost:4200

# Environment mode.
NODE_ENV=development

# -----------------------------------------------------------------------------
# tekmar-pipeline (Pipeline Service)
# -----------------------------------------------------------------------------
# LLM provider: anthropic, openai, or ollama.
LLM_PROVIDER=anthropic

# API key for Anthropic Claude (required if LLM_PROVIDER=anthropic).
ANTHROPIC_API_KEY=CHANGE_ME

# API key for OpenAI GPT (required if LLM_PROVIDER=openai).
OPENAI_API_KEY=CHANGE_ME

# Ollama server URL (required if LLM_PROVIDER=ollama).
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name.
OLLAMA_MODEL=llama3

# Maximum tokens for LLM responses.
LLM_MAX_TOKENS=4096

# LLM temperature for plan generation (low = more deterministic).
LLM_TEMPERATURE=0.1

# Path to MCP server configuration file.
MCP_SERVERS_CONFIG=./mcp_servers.yaml

# Maximum total execution time per query (seconds).
EXECUTION_TIMEOUT_SECONDS=300

# Maximum time per individual step (seconds).
STEP_TIMEOUT_SECONDS=30

# Logging level.
LOG_LEVEL=INFO

GITHUB_TEST_PAT="ghp_example_token"
GITHUB_TEST_ORG="example_org_name"